* {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: Inter, Arial, Helvetica, sans-serif;
  background: #07111f;
  color: #eaf2ff;
}

button,
input,
textarea,
select {
  font: inherit;
}

.login-page {
  min-height: 100vh;
  display: grid;
  place-items: center;
  background:
    radial-gradient(circle at top left, rgba(0, 212, 255, 0.18), transparent 30%),
    radial-gradient(circle at bottom right, rgba(34, 197, 94, 0.15), transparent 30%),
    #07111f;
  padding: 20px;
}

.login-card {
  width: 100%;
  max-width: 460px;
  background: rgba(15, 28, 48, 0.92);
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 24px;
  padding: 28px;
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
}

.logo-area {
  display: flex;
  gap: 16px;
  align-items: center;
  margin-bottom: 24px;
}

.logo {
  width: 56px;
  height: 56px;
  border-radius: 18px;
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, #0ea5e9, #22c55e);
  color: white;
  font-weight: 900;
  letter-spacing: 1px;
}

.logo.small {
  width: 42px;
  height: 42px;
  border-radius: 14px;
}

.logo-area h1,
.page-header h1 {
  margin: 0;
}

.logo-area p,
.page-header p,
.hint,
.empty,
.card span,
.linha span,
small {
  color: #94a3b8;
}

.form {
  display: grid;
  gap: 10px;
}

input,
textarea,
select {
  width: 100%;
  background: #0b1728;
  color: #eaf2ff;
  border: 1px solid rgba(148, 163, 184, 0.24);
  border-radius: 12px;
  padding: 12px 14px;
  outline: none;
}

textarea {
  min-height: 110px;
  resize: vertical;
}

input:focus,
textarea:focus,
select:focus {
  border-color: #38bdf8;
}

.btn {
  border: 0;
  border-radius: 12px;
  padding: 11px 14px;
  background: #1e293b;
  color: #eaf2ff;
  cursor: pointer;
  transition: 0.2s;
  text-decoration: none;
  display: inline-block;
  text-align: center;
}

.btn:hover {
  transform: translateY(-1px);
  filter: brightness(1.08);
}

.btn.primary {
  background: linear-gradient(135deg, #0284c7, #16a34a);
  font-weight: 700;
}

.btn.ghost {
  background: transparent;
  border: 1px solid rgba(148, 163, 184, 0.25);
}

.btn.danger {
  background: #7f1d1d;
}

.btn.sair {
  width: 100%;
  background: #172033;
  margin-top: 12px;
}

.alerta {
  background: rgba(251, 191, 36, 0.12);
  border: 1px solid rgba(251, 191, 36, 0.35);
  color: #fde68a;
  border-radius: 12px;
  padding: 10px;
}

.app-shell {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 270px 1fr;
}

.sidebar {
  position: sticky;
  top: 0;
  height: 100vh;
  background: #091525;
  border-right: 1px solid rgba(148, 163, 184, 0.14);
  padding: 20px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 28px;
}

.brand span {
  display: block;
  color: #94a3b8;
  font-size: 13px;
}

.sidebar nav {
  display: grid;
  gap: 8px;
}

.sidebar nav button {
  display: flex;
  gap: 10px;
  align-items: center;
  text-align: left;
  background: transparent;
  color: #cbd5e1;
  border: 0;
  border-radius: 14px;
  padding: 12px;
  cursor: pointer;
}

.sidebar nav button.active,
.sidebar nav button:hover {
  background: rgba(14, 165, 233, 0.14);
  color: #f8fafc;
}

.user-box {
  margin-top: auto;
  padding-top: 20px;
}

.user-box p {
  color: #94a3b8;
  margin: 0 0 4px;
  font-size: 13px;
}

.user-box strong,
.user-box small {
  display: block;
  word-break: break-all;
}

.main-content {
  padding: 28px;
  overflow: auto;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: start;
  gap: 18px;
  margin-bottom: 24px;
}

.top-user {
  min-width: 190px;
  background: rgba(15, 28, 48, 0.85);
  border: 1px solid rgba(148, 163, 184, 0.15);
  border-radius: 18px;
  padding: 12px 16px;
  text-align: right;
}

.top-user span {
  display: block;
  color: #94a3b8;
  font-size: 12px;
}

.top-user strong {
  display: block;
  font-size: 18px;
}

.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 16px;
  margin-bottom: 18px;
}

.card,
.panel {
  background: rgba(15, 28, 48, 0.85);
  border: 1px solid rgba(148, 163, 184, 0.15);
  border-radius: 20px;
  padding: 18px;
  box-shadow: 0 16px 38px rgba(0, 0, 0, 0.18);
}

.card p {
  margin: 0 0 8px;
  color: #94a3b8;
}

.card h2 {
  font-size: 34px;
  margin: 0 0 8px;
}

.grid-2 {
  display: grid;
  grid-template-columns: 0.9fr 1.1fr;
  gap: 18px;
  margin-bottom: 18px;
}

.form-grid {
  display: grid;
  gap: 12px;
  margin-bottom: 18px;
}

.lista {
  display: grid;
  gap: 14px;
}

.item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.item h3,
.item p {
  margin: 0 0 7px;
}

.item p {
  color: #cbd5e1;
}

.botoes {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: end;
}

.botoes.esquerda {
  justify-content: start;
}

.linha {
  padding: 12px 0;
  border-bottom: 1px solid rgba(148, 163, 184, 0.12);
}

.linha strong,
.linha span {
  display: block;
}

.empty.big {
  min-height: 260px;
  display: grid;
  place-items: center;
  text-align: center;
}

.empty.box {
  border: 1px dashed rgba(148, 163, 184, 0.22);
  border-radius: 16px;
  padding: 18px;
}

.resultado-comando {
  background: rgba(14, 165, 233, 0.12);
  border: 1px solid rgba(14, 165, 233, 0.22);
  border-radius: 16px;
  padding: 16px;
}

.resultado-comando p {
  color: #dbeafe;
  white-space: pre-wrap;
}

.links-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(220px, 1fr));
  gap: 16px;
}

.link-card {
  display: grid;
  gap: 14px;
}

.link-card h3,
.link-card p {
  margin: 0 0 7px;
}

.sheet-frame {
  width: 100%;
  height: 72vh;
  border: 0;
  border-radius: 16px;
  background: white;
}

.calendar-panel {
  overflow: hidden;
}

.fc {
  color: #eaf2ff;
}

.fc .fc-toolbar-title {
  font-size: 20px;
}

.fc .fc-button {
  background: #1e293b;
  border: 0;
}

.fc .fc-daygrid-day-number,
.fc .fc-col-header-cell-cushion {
  color: #eaf2ff;
  text-decoration: none;
}

.fc-theme-standard td,
.fc-theme-standard th,
.fc-theme-standard .fc-scrollgrid {
  border-color: rgba(148, 163, 184, 0.18);
}

.timer-item strong {
  font-size: 18px;
  white-space: nowrap;
}

.ok-prazo {
  color: #86efac;
}

.alerta-prazo {
  color: #fde047;
}

.vencido {
  color: #fca5a5;
}

.passos {
  color: #cbd5e1;
  line-height: 1.8;
}

@media (max-width: 1080px) {
  .cards-grid,
  .links-grid {
    grid-template-columns: repeat(2, minmax(160px, 1fr));
  }

  .grid-2 {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 820px) {
  .app-shell {
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: static;
    height: auto;
  }

  .sidebar nav {
    grid-template-columns: repeat(2, 1fr);
  }

  .cards-grid,
  .links-grid {
    grid-template-columns: 1fr;
  }

  .item {
    align-items: start;
    flex-direction: column;
  }

  .page-header {
    flex-direction: column;
  }

  .top-user {
    width: 100%;
    text-align: left;
  }
}


.preview-texto {
  white-space: pre-wrap;
  background: #0b1728;
  color: #eaf2ff;
  border: 1px solid rgba(148, 163, 184, 0.22);
  border-radius: 14px;
  padding: 14px;
  line-height: 1.5;
  min-height: 220px;
  overflow: auto;
}

.contador-inline {
  margin-top: 10px;
  font-weight: 800;
  font-size: 14px;
}


.avatar-mini {
  width: 58px;
  height: 58px;
  border-radius: 18px;
  object-fit: cover;
  border: 2px solid rgba(14, 165, 233, 0.45);
  margin-bottom: 10px;
}

.top-user {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12px;
}

.avatar-top {
  width: 48px;
  height: 48px;
  border-radius: 16px;
  object-fit: cover;
  border: 2px solid rgba(14, 165, 233, 0.45);
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(110px, 1fr));
  gap: 12px;
}

.avatar-option {
  background: #0b1728;
  border: 1px solid rgba(148, 163, 184, 0.24);
  border-radius: 16px;
  padding: 10px;
  color: #eaf2ff;
  cursor: pointer;
  display: grid;
  gap: 8px;
  text-align: center;
}

.avatar-option.active {
  border-color: #22c55e;
  box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.25);
}

.avatar-option img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 12px;
}

.avatar-option span {
  font-size: 13px;
  color: #cbd5e1;
}

.perfil-preview {
  display: grid;
  place-items: center;
  text-align: center;
  align-content: center;
  gap: 14px;
}

.avatar-preview {
  width: 180px;
  height: 180px;
  object-fit: cover;
  border-radius: 32px;
  border: 3px solid rgba(14, 165, 233, 0.45);
}

@media (max-width: 820px) {
  .avatar-grid {
    grid-template-columns: repeat(2, minmax(110px, 1fr));
  }

  .top-user {
    justify-content: flex-start;
  }
}


/* Correção do menu lateral:
   o menu pode rolar, mas a área do usuário e o botão Sair ficam sempre visíveis. */
.sidebar nav {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding-right: 4px;
}

.user-box {
  flex-shrink: 0;
  border-top: 1px solid rgba(148, 163, 184, 0.14);
  background: #091525;
}

/* Detalhe do evento ao clicar no calendário */
.evento-detalhe {
  margin-top: 16px;
  background: rgba(14, 165, 233, 0.10);
  border: 1px solid rgba(14, 165, 233, 0.25);
  border-radius: 16px;
  padding: 14px;
  display: grid;
  gap: 12px;
}

.evento-detalhe h3,
.evento-detalhe p {
  margin: 0 0 8px;
}

.fc-event {
  cursor: pointer;
}
